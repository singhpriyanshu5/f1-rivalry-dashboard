    {
      "type": "text",
      "id": "d_ai_storage_text",
      "x": 670,
      "y": 2030,
      "width": 310,
      "height": 150,
      "text": "RAW_SEASON_NARRATIVES Schema:\n\n  season              INTEGER\n  constructor_id      VARCHAR\n  driver_1_code       VARCHAR(3)\n  driver_2_code       VARCHAR(3)\n  narrative_text      VARCHAR(16384)\n  model_id            VARCHAR(100)\n  prompt_hash         VARCHAR(64)  ← SHA-256\n  generated_at        TIMESTAMP_NTZ\n\nWrite: DELETE + INSERT (idempotent)\nCache: skip API call if prompt_hash matches\nCost: $0 for completed seasons after 1st gen",
      "originalText": "RAW_SEASON_NARRATIVES Schema:\n\n  season              INTEGER\n  constructor_id      VARCHAR\n  driver_1_code       VARCHAR(3)\n  driver_2_code       VARCHAR(3)\n  narrative_text      VARCHAR(16384)\n  model_id            VARCHAR(100)\n  prompt_hash         VARCHAR(64)  ← SHA-256\n  generated_at        TIMESTAMP_NTZ\n\nWrite: DELETE + INSERT (idempotent)\nCache: skip API call if prompt_hash matches\nCost: $0 for completed seasons after 1st gen",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 900151,
      "version": 1,
      "versionNonce": 900151,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": [],
      "link": null,
      "locked": false,
      "containerId": "d_ai_storage_box",
      "lineHeight": 1.25
    },
