    {
      "type": "text",
      "id": "stg_transform_text",
      "x": 654.7831739517328,
      "y": 568.4297970584702,
      "width": 251.3671875,
      "height": 192.5,
      "text": "Key Staging Transformations:\n\nstg_qualifying:\n  LATERAL FLATTEN \u2192 parse \"1:23.456\"\n  \u2192 best_time_ms = COALESCE(q3,q2,q1)\n\nstg_laps:\n  FLATTEN lap timing entries\n  \u2192 lap_time_seconds (\"1:32.100\"\u219292.1)\n\nstg_results / stg_sprint_results:\n  FLATTEN \u2192 grid, position, points,\n  status, laps_completed\n  (used for driver-constructor mapping)",
      "originalText": "Key Staging Transformations:\n\nstg_qualifying:\n  LATERAL FLATTEN \u2192 parse \"1:23.456\"\n  \u2192 best_time_ms = COALESCE(q3,q2,q1)\n\nstg_laps:\n  FLATTEN lap timing entries\n  \u2192 lap_time_seconds (\"1:32.100\"\u219292.1)\n\nstg_results / stg_sprint_results:\n  FLATTEN \u2192 grid, position, points,\n  status, laps_completed\n  (used for driver-constructor mapping)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
