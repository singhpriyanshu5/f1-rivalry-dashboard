    {
      "type": "text",
      "id": "mart_detail_text",
      "x": 671.8525755377283,
      "y": 942.3162795107535,
      "width": 257.8125,
      "height": 426.25,
      "text": "Mart Transformations:\n\nmart_qualifying_h2h:\n  Self-join on constructor per round\n  gap_ms = d1_time - d2_time\n\nmart_race_h2h:\n  Teammate pairing per round\n  DNF category, places_gained\n\nmart_sprint_h2h:\n  Sprint race teammate pairing\n  sprint_winner_code, grid vs finish\n\nmart_lap_pace:\n  Filter safety car laps (>1.5\u00d7 median)\n\nmart_pit_stop_h2h:\n  Pair teammates by stop number\n  Duration diff, who pitted first\n\nmart_season_summary:\n  7 verdicts: qual, race, sprint race,\n  sprint quali, pts, rel, pit\n\nmart_lap_pace_summary:\n  Median, stddev, IQR, consistency score\n\nmart_season_narrative:\n  Claude Sonnet 4 \u2192 HTML snippet\n  Prompt-hash cached per pairing",
      "originalText": "Mart Transformations:\n\nmart_qualifying_h2h:\n  Self-join on constructor per round\n  gap_ms = d1_time - d2_time\n\nmart_race_h2h:\n  Teammate pairing per round\n  DNF category, places_gained\n\nmart_sprint_h2h:\n  Sprint race teammate pairing\n  sprint_winner_code, grid vs finish\n\nmart_lap_pace:\n  Filter safety car laps (>1.5\u00d7 median)\n\nmart_pit_stop_h2h:\n  Pair teammates by stop number\n  Duration diff, who pitted first\n\nmart_season_summary:\n  7 verdicts: qual, race, sprint race,\n  sprint quali, pts, rel, pit\n\nmart_lap_pace_summary:\n  Median, stddev, IQR, consistency score\n\nmart_season_narrative:\n  Claude Sonnet 4 \u2192 HTML snippet\n  Prompt-hash cached per pairing",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
