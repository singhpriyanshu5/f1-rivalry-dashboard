    {
      "type": "text",
      "id": "d_ai_prompt_text",
      "x": 300,
      "y": 2030,
      "width": 320,
      "height": 150,
      "text": "Prompt Structure:\n\nSystem: \"You are an F1 analyst...\"\nUser: {\n  season_summary: { ... },\n  qualifying: [ {round, gap_ms, ...} ],\n  races: [ {round, winner, points, ...} ],\n  standings: { cumulative_points },\n  pace: { avg_consistency, avg_median },\n  sprints: [ ... ] (if data exists)\n}\n\nOutput: Structured HTML with CSS classes\n  f1-narrative-hook, f1-narrative-bullets,\n  f1-narrative-item, f1-narrative-label",
      "originalText": "Prompt Structure:\n\nSystem: \"You are an F1 analyst...\"\nUser: {\n  season_summary: { ... },\n  qualifying: [ {round, gap_ms, ...} ],\n  races: [ {round, winner, points, ...} ],\n  standings: { cumulative_points },\n  pace: { avg_consistency, avg_median },\n  sprints: [ ... ] (if data exists)\n}\n\nOutput: Structured HTML with CSS classes\n  f1-narrative-hook, f1-narrative-bullets,\n  f1-narrative-item, f1-narrative-label",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
