    {
      "type": "text",
      "id": "ev_theme_note",
      "x": 33.10877271106773,
      "y": 1762.6603873045112,
      "width": 500,
      "height": 70,
      "text": "UI Theme: Dark Motorsport Telemetry\n\u2022 Fonts: Saira Condensed + Saira (Google Fonts)\n\u2022 Colors: F1 Red (#E10600), Mercedes Teal (#00D2BE), carbon backgrounds\n\u2022 seriesColors prop: D1=red, D2=teal (explicit, not order-based)\n\u2022 Driver name legend panel below controls\n\u2022 patch-package preserves Evidence component patches",
      "originalText": "UI Theme: Dark Motorsport Telemetry\n\u2022 Fonts: Saira Condensed + Saira (Google Fonts)\n\u2022 Colors: F1 Red (#E10600), Mercedes Teal (#00D2BE), carbon backgrounds\n\u2022 seriesColors prop: D1=red, D2=teal (explicit, not order-based)\n\u2022 Driver name legend panel below controls\n\u2022 patch-package preserves Evidence component patches",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
