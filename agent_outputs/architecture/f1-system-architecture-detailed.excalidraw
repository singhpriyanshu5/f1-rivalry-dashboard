    {
      "type": "text",
      "id": "dbt_dag_text",
      "x": 1090,
      "y": 750,
      "width": 300,
      "height": 210,
      "text": "dbt Model DAG:\n\nRAW_QUALIFYING ──→ stg_qualifying\n  ├→ dim_drivers, dim_constructors\n  └→ mart_qualifying_h2h → mart_season_summary\nRAW_RESULTS ──→ stg_results\n  └→ mart_race_h2h → mart_season_summary\nRAW_STANDINGS ──→ stg_driver_standings\n  └→ mart_points_trajectory\nRAW_LAPS ──→ stg_laps\n  └→ mart_lap_pace → mart_lap_pace_summary\nRAW_PIT_STOPS ──→ stg_pit_stops\n  └→ mart_pit_stop_h2h → mart_season_summary\nRAW_SCHEDULE ──→ stg_schedule → dim_races",
      "originalText": "dbt Model DAG:\n\nRAW_QUALIFYING ──→ stg_qualifying\n  ├→ dim_drivers, dim_constructors\n  └→ mart_qualifying_h2h → mart_season_summary\nRAW_RESULTS ──→ stg_results\n  └→ mart_race_h2h → mart_season_summary\nRAW_STANDINGS ──→ stg_driver_standings\n  └→ mart_points_trajectory\nRAW_LAPS ──→ stg_laps\n  └→ mart_lap_pace → mart_lap_pace_summary\nRAW_PIT_STOPS ──→ stg_pit_stops\n  └→ mart_pit_stop_h2h → mart_season_summary\nRAW_SCHEDULE ──→ stg_schedule → dim_races",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
