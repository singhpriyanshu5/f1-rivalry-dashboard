      "x": 660,
      "y": 810,
      "width": 360,
      "height": 110,
      "text": "Dimension Details:\n\ndim_drivers: driver_id, code, full_name\ndim_constructors: constructor_id, name\ndim_dnf_status: 98 status strings →\n  mechanical | crash | finished | other\n  (from seed CSV)\ndim_races: round_label = \"R01 Melbourne\"",
      "originalText": "Dimension Details:\n\ndim_drivers: driver_id, code, full_name\ndim_constructors: constructor_id, name\ndim_dnf_status: 98 status strings →\n  mechanical | crash | finished | other\n  (from seed CSV)\ndim_races: round_label = \"R01 Melbourne\"",
      "fontSize": 11,
