      "id": "dbt_dag_text",
      "x": 1085,
      "y": 772.2430698058454,
      "width": 269.53125,
      "height": 175,
      "text": "dbt Model DAG:\n\nRAW_QUALIFYING \u2500\u2500\u2192 stg_qualifying\n  \u251c\u2192 dim_drivers, dim_constructors\n  \u2514\u2192 mart_qualifying_h2h \u2192 mart_season_summary\nRAW_RESULTS \u2500\u2500\u2192 stg_results\n  \u2514\u2192 mart_race_h2h \u2192 mart_season_summary\nRAW_STANDINGS \u2500\u2500\u2192 stg_driver_standings\n  \u2514\u2192 mart_points_trajectory\nRAW_LAPS \u2500\u2500\u2192 stg_laps\n  \u2514\u2192 mart_lap_pace \u2192 mart_lap_pace_summary\nRAW_PIT_STOPS \u2500\u2500\u2192 stg_pit_stops\n  \u2514\u2192 mart_pit_stop_h2h \u2192 mart_season_summary\nRAW_SCHEDULE \u2500\u2500\u2192 stg_schedule \u2192 dim_races",
      "originalText": "dbt Model DAG:\n\nRAW_QUALIFYING \u2500\u2500\u2192 stg_qualifying\n  \u251c\u2192 dim_drivers, dim_constructors\n  \u2514\u2192 mart_qualifying_h2h \u2192 mart_season_summary\nRAW_RESULTS \u2500\u2500\u2192 stg_results\n  \u2514\u2192 mart_race_h2h \u2192 mart_season_summary\nRAW_STANDINGS \u2500\u2500\u2192 stg_driver_standings\n  \u2514\u2192 mart_points_trajectory\nRAW_LAPS \u2500\u2500\u2192 stg_laps\n  \u2514\u2192 mart_lap_pace \u2192 mart_lap_pace_summary\nRAW_PIT_STOPS \u2500\u2500\u2192 stg_pit_stops\n  \u2514\u2192 mart_pit_stop_h2h \u2192 mart_season_summary\nRAW_SCHEDULE \u2500\u2500\u2192 stg_schedule \u2192 dim_races",
