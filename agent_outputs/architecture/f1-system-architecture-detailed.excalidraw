    {
      "type": "text",
      "id": "stg_transform_text",
      "x": 660,
      "y": 600,
      "width": 360,
      "height": 175,
      "text": "Key Staging Transformations:\n\nstg_qualifying:\n  LATERAL FLATTEN → parse \"1:23.456\"\n  → best_time_ms = COALESCE(q3,q2,q1)\n\nstg_laps:\n  FLATTEN lap timing entries\n  → lap_time_seconds (\"1:32.100\"→92.1)\n\nstg_results:\n  FLATTEN → grid, position, points,\n  status, laps_completed\n  (used for driver-constructor mapping)",
      "originalText": "Key Staging Transformations:\n\nstg_qualifying:\n  LATERAL FLATTEN → parse \"1:23.456\"\n  → best_time_ms = COALESCE(q3,q2,q1)\n\nstg_laps:\n  FLATTEN lap timing entries\n  → lap_time_seconds (\"1:32.100\"→92.1)\n\nstg_results:\n  FLATTEN → grid, position, points,\n  status, laps_completed\n  (used for driver-constructor mapping)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 300085,
      "version": 1,
      "versionNonce": 300086,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": "stg_transform_box",
      "lineHeight": 1.25
    },

