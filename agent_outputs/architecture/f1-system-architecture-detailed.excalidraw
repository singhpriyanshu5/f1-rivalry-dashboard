    {
      "type": "text",
      "id": "ev_theme_note",
      "x": 60,
      "y": 1590,
      "width": 500,
      "height": 70,
      "text": "UI Theme: Dark Motorsport Telemetry\n• Fonts: Saira Condensed + Saira (Google Fonts)\n• Colors: F1 Red (#E10600), Mercedes Teal (#00D2BE), carbon backgrounds\n• seriesColors prop: D1=red, D2=teal (explicit, not order-based)\n• Driver name legend panel below controls\n• patch-package preserves Evidence component patches",
      "originalText": "UI Theme: Dark Motorsport Telemetry\n• Fonts: Saira Condensed + Saira (Google Fonts)\n• Colors: F1 Red (#E10600), Mercedes Teal (#00D2BE), carbon backgrounds\n• seriesColors prop: D1=red, D2=teal (explicit, not order-based)\n• Driver name legend panel below controls\n• patch-package preserves Evidence component patches",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
